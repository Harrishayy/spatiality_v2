# Copy to .env and fill in. .env is gitignored.

# ─── Hugging Face (only if a chosen model is gated) ──────────────────────
# HF_TOKEN=hf_...

# ─── LLM / VLM provider keys (fill in once we pick providers) ────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Pydantic AI Gateway (optional unified provider proxy) ───────────────
# PYDANTIC_AI_GATEWAY_API_KEY=pylf_v...
# PYDANTIC_AI_GATEWAY_BASE_URL=https://gateway-eu.pydantic.dev/proxy/anthropic

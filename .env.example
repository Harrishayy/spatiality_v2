# Copy to .env and fill in. .env is gitignored.

# ─── Hugging Face (for SAM 3.1 / SpatialLM weights) ─────────────────────
# HF_TOKEN=hf_...

# ─── Gemini for the VLM lanes B + E (default) ───────────────────────────
# Lane B + E use PydanticAI with Gemini 2.5 Flash by default; switch to
# gemini-2.5-flash-lite (cheaper, faster) by setting SPATIALITY_VLM_MODEL.
# GEMINI_API_KEY=...
# SPATIALITY_VLM_MODEL=gemini-2.5-flash         # or gemini-2.5-flash-lite

# ─── Claude (only if a job overrides vlm_model to a claude-* id) ─────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Pydantic AI Gateway (optional unified provider proxy) ───────────────
# PYDANTIC_AI_GATEWAY_API_KEY=pylf_v...
# PYDANTIC_AI_GATEWAY_BASE_URL=https://gateway-eu.pydantic.dev/proxy
